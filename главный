@dp.callback_query(lambda c: c.data.startswith("admin:"))
async def process_admin_callback(callback: CallbackQuery, state: FSMContext):
    action = callback.data.split(":")[1]

    if not is_admin(callback.from_user):
        await callback.answer("Недостаточно прав.")
        return

    if action == "add":
        await callback.message.delete()
        await callback.message.answer("Введите название приложения:")
        await state.set_state(AddApp.name)
        await callback.answer()

    elif action == "delete":
        apps = get_all_apps()
        if not apps:
            await callback.message.edit_text("Список приложений пуст.")
            await callback.answer()
            return
        kb_buttons = []
        for app in apps:
            app_id, name, _, _, _, platform = app
            short_name = name if len(name) <= 30 else name[:27] + "..."
            # Добавляем метку платформы
            platform_emoji = "📱" if platform == "android" else "🍏" if platform == "ios" else "🔄"
            kb_buttons.append([InlineKeyboardButton(
                text=f"ID {app_id}: {short_name} {platform_emoji}",
                callback_data=f"del:{app_id}"
            )])
        kb_buttons.append([InlineKeyboardButton(text="◀️ Назад", callback_data="admin:back")])
        keyboard = InlineKeyboardMarkup(inline_keyboard=kb_buttons)
        await callback.message.edit_text("Выберите приложение для удаления:", reply_markup=keyboard)
        await callback.answer()

    elif action == "list":
        apps = get_all_apps()
        if not apps:
            text = "Список приложений пуст."
        else:
            text = "📋 Список приложений:\n"
            for app in apps:
                app_id, name, _, _, _, platform = app
                platform_text = {"android": "Android", "ios": "iOS", "both": "Обе"}[platform]
                text += f"ID: {app_id} — {name} ({platform_text})\n"
        keyboard = InlineKeyboardMarkup(inline_keyboard=[
            [InlineKeyboardButton(text="◀️ Назад", callback_data="admin:back")]
        ])
        await callback.message.edit_text(text, reply_markup=keyboard)
        await callback.answer()

    elif action == "referrals":
        data = get_all_users_with_referrers()
        if not data:
            await callback.message.edit_text("В базе нет пользователей.")
            await callback.answer()
            return

        text = "📊 <b>Все пользователи и рефералы:</b>\n\n"
        for row in data:
            uid, uname, fname, ref_by, ref_uname, ref_fname = row
            line = f"• {fname} (ID: {uid})"
            if uname:
                line += f" @{uname}"
            if ref_by:
                line += f"\n  приглашён: {ref_fname or ''}"
                if ref_uname:
                    line += f" (@{ref_uname})"
            else:
                line += "\n  пришёл самостоятельно"
            text += line + "\n\n"

        if len(text) > 3500:
            text = text[:3500] + "\n\n... (обрезано)"

        keyboard = InlineKeyboardMarkup(inline_keyboard=[
            [InlineKeyboardButton(text="◀️ Назад", callback_data="admin:back")]
        ])
        await callback.message.edit_text(text, parse_mode="HTML", reply_markup=keyboard)
        await callback.answer()

    elif action == "cancel":
        await callback.message.delete()
        await callback.answer("Панель закрыта.")
        await state.clear()

    elif action == "back":
        await callback.message.edit_text("👑 Панель администратора:", reply_markup=get_admin_keyboard())
        await callback.answer()


# ==================== ИНИЦИАЛИЗАЦИЯ БД ====================
def init_db():
    conn = sqlite3.connect(DB_NAME)
    cur = conn.cursor()
    # Таблица приложений (добавлено поле platform)
    cur.execute("""
        CREATE TABLE IF NOT EXISTS apps (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            description TEXT NOT NULL,
            link TEXT NOT NULL,
            photo_file_id TEXT,
            platform TEXT NOT NULL DEFAULT 'both'
        )
    """)
    # Таблица пользователей
    cur.execute("""
        CREATE TABLE IF NOT EXISTS users (
            user_id INTEGER PRIMARY KEY,
            username TEXT,
            first_name TEXT,
            referred_by INTEGER,
            registered_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (referred_by) REFERENCES users(user_id)
        )
    """)
    conn.commit()
    conn.close()

init_db()

# ==================== РАБОТА С ПРИЛОЖЕНИЯМИ ====================
def get_all_apps():
    conn = sqlite3.connect(DB_NAME)
    cur = conn.cursor()
    cur.execute("SELECT id, name, description, link, photo_file_id, platform FROM apps ORDER BY id")
    rows = cur.fetchall()
    conn.close()
    return rows

def add_app(name, description, link, photo_file_id=None, platform='both'):
    conn = sqlite3.connect(DB_NAME)
    cur = conn.cursor()
    cur.execute(
        "INSERT INTO apps (name, description, link, photo_file_id, platform) VALUES (?, ?, ?, ?, ?)",
        (name, description, link, photo_file_id, platform)
    )
    conn.commit()
    app_id = cur.lastrowid
    conn.close()
    return app_id

def delete_app(app_id):
    conn = sqlite3.connect(DB_NAME)
    cur = conn.cursor()
    cur.execute("DELETE FROM apps WHERE id=?", (app_id,))
    conn.commit()
    deleted = cur.rowcount > 0
    conn.close()
    return deleted

# ==================== РАБОТА С ПОЛЬЗОВАТЕЛЯМИ ====================
def get_user(user_id):
    conn = sqlite3.connect(DB_NAME)
    cur = conn.cursor()
    cur.execute("SELECT user_id, username, first_name, referred_by FROM users WHERE user_id=?", (user_id,))
    row = cur.fetchone()
    conn.close()
    return row

def add_user(user_id, username, first_name, referred_by=None):
    conn = sqlite3.connect(DB_NAME)
    cur = conn.cursor()
    try:
        cur.execute(
            "INSERT INTO users (user_id, username, first_name, referred_by) VALUES (?, ?, ?, ?)",
            (user_id, username, first_name, referred_by)
        )
        conn.commit()
    except sqlite3.IntegrityError:
        # Пользователь уже существует
        pass
    finally:
        conn.close()

def get_referrals(user_id):
    """Возвращает список приглашённых пользователей (user_id, username, first_name)"""
    conn = sqlite3.connect(DB_NAME)
    cur = conn.cursor()
    cur.execute(
        "SELECT user_id, username, first_name FROM users WHERE referred_by=?",
        (user_id,)
    )
    rows = cur.fetchall()
    conn.close()
    return rows

def get_all_users_with_referrers():
    """Для админа: все пользователи и кто пригласил"""
    conn = sqlite3.connect(DB_NAME)
    cur = conn.cursor()
    cur.execute("""
        SELECT u.user_id, u.username, u.first_name, u.referred_by,
               r.username, r.first_name
        FROM users u
        LEFT JOIN users r ON u.referred_by = r.user_id
        ORDER BY u.registered_at
    """)
    rows = cur.fetchall()
    conn.close()
    return rows

def get_referrer_info(user_id):
    """Возвращает информацию о том, кто пригласил данного пользователя"""
    conn = sqlite3.connect(DB_NAME)
    cur = conn.cursor()
    cur.execute("""
        SELECT u.user_id, u.username, u.first_name
        FROM users u
        WHERE u.user_id = (SELECT referred_by FROM users WHERE user_id = ?)
    """, (user_id,))
    row = cur.fetchone()
    conn.close()
    return row


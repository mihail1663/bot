def extract_username(input_text: str) -> Optional[str]:
    input_text = input_text.strip()
    if input_text.startswith('@'):
        return input_text[1:]
    match = re.search(r'(?:https?://)?t\.me/([a-zA-Z0-9_]+)', input_text)
    if match:
        return match.group(1)
    if re.match(r'^[a-zA-Z0-9_]+$', input_text):
        return input_text
    return None


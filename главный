@dp.message(AddApp.points, Command("done"))
async def finish_points(message: Message, state: FSMContext):
    data = await state.get_data()
    points = data.get('points', [])
    if not points:
        await message.answer("Вы не ввели ни одного пункта. Описание не может быть пустым. Введите хотя бы один пункт или отмените добавление командой /cancel.")
        return
    description = "\n".join(f"{i+1}. {point}" for i, point in enumerate(points))
    await state.update_data(description=description)
    await message.answer("Введите ссылку:", reply_markup=ReplyKeyboardRemove())
    await state.set_state(AddApp.link)

@dp.message(AddApp.points)
async def add_point(message: Message, state: FSMContext):
    point = message.text.strip()
    if not point:
        await message.answer("Пункт не может быть пустым. Введите текст или нажмите кнопку завершения.")
        return
    data = await state.get_data()
    points = data.get('points', [])
    points.append(point)
    await state.update_data(points=points)
    await message.answer(f"Пункт {len(points)} добавлен. Введите следующий пункт или нажмите кнопку завершения.")


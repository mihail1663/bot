async def send_app_message(chat_id, user_id, index):
    try:
        apps = get_all_apps()
        if index < 0 or index >= len(apps):
            return
        app = apps[index]
        app_id, name, description, link, photo_file_id, platform, ctype = app

        platform_emoji = "📱" if platform == "android" else "🍏" if platform == "ios" else "🔄"
        platform_text = {"android": "Android", "ios": "iOS", "both": "Android и iOS"}[platform]
        type_emoji = "📱" if ctype == "app" else "🌐"
        type_text = "Приложение" if ctype == "app" else "Сайт"

        app_count = get_count_by_type('app')
        site_count = get_count_by_type('site')
        counter_info = f"📊 Всего приложений: {app_count}, сайтов: {site_count}"

        text = f"<b>{name}</b>\n\n{description}\n\n{type_emoji} {type_text}\n{platform_emoji} {platform_text}\n\n<a href='{link}'>🔗 Ссылка</a>\n\n{counter_info}"

        buttons = []
        if index > 0:
            buttons.append(InlineKeyboardButton(text="◀️", callback_data=f"nav:prev:{index}"))
        if index < len(apps) - 1:
            buttons.append(InlineKeyboardButton(text="▶️", callback_data=f"nav:next:{index}"))
        counter = InlineKeyboardButton(text=f"{index+1}/{len(apps)}", callback_data="ignore")
        if buttons:
            keyboard = InlineKeyboardMarkup(inline_keyboard=[buttons, [counter]])
        else:
            keyboard = InlineKeyboardMarkup(inline_keyboard=[[counter]])

        if photo_file_id:
            await bot.send_photo(chat_id, photo_file_id, caption=text, parse_mode="HTML", reply_markup=keyboard)
        else:
            await bot.send_message(chat_id, text, parse_mode="HTML", reply_markup=keyboard)
    except Exception as e:
        logging.error(f"send_app_message error: {e}")

@dp.callback_query(lambda c: c.data.startswith("nav:"))
async def process_navigation(callback: CallbackQuery):
    try:
        data = callback.data.split(":")
        action = data[1]
        current_index = int(data[2])
        user_id = callback.from_user.id
        apps = get_all_apps()
        if not apps:
            await callback.answer("Нет элементов.")
            return
        new_index = current_index
        if action == "prev" and current_index > 0:
            new_index = current_index - 1
        elif action == "next" and current_index < len(apps) - 1:
            new_index = current_index + 1
        else:
            await callback.answer("Невозможно перейти")
            return
        user_app_index[user_id] = new_index
        await callback.message.delete()
        await send_app_message(callback.message.chat.id, user_id, new_index)
        await callback.answer()
    except Exception as e:
        logging.error(f"navigation error: {e}")
        await callback.answer("Ошибка навигации.")


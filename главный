@dp.message(Command("start"))
async def cmd_start(message: Message, command: CommandObject):
    try:
        user_id = message.from_user.id
        username = message.from_user.username
        first_name = message.from_user.first_name

        if not is_admin(message.from_user) and not await is_subscribed(user_id):
            channel_link = get_setting('channel_link')
            group_link = get_setting('group_link')
            text_parts = ["Для использования бота необходимо подписаться"]
            inline_buttons = []
            if channel_link:
                text_parts.append(f"📢 на канал: {channel_link}")
                inline_buttons.append([InlineKeyboardButton(text="📢 Канал", url=channel_link)])
            if group_link:
                text_parts.append(f"👥 на группу: {group_link}")
                inline_buttons.append([InlineKeyboardButton(text="👥 Группа", url=group_link)])
            if not channel_link and not group_link:
                text_parts.append("(ссылки не заданы администратором)")
            text_parts.append("После подписки нажмите кнопку «Проверить подписку».")
            text = "\n".join(text_parts)
            inline_buttons.append([InlineKeyboardButton(text="✅ Проверить подписку", callback_data="check_sub")])
            keyboard = InlineKeyboardMarkup(inline_keyboard=inline_buttons)
            await message.answer(text, reply_markup=keyboard)
            return

        existing = get_user(user_id)
        if not existing:
            referred_by = None
            if command.args:
                try:
                    ref_id = int(command.args)
                    if ref_id != user_id and get_user(ref_id) is not None:
                        referred_by = ref_id
                except ValueError:
                    pass
            add_user(user_id, username, first_name, referred_by)
            await message.answer(
                "👋 Добро пожаловать! Я бот с полезными приложениями и сайтами.\n"
                "Используй кнопки ниже для навигации.",
                reply_markup=reply_keyboard
            )
        else:
            update_last_active(user_id)
            await message.answer("С возвращением!", reply_markup=reply_keyboard)
    except Exception as e:

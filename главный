@dp.callback_query(AddApp.platform)
async def process_platform(callback: CallbackQuery, state: FSMContext):
    action = callback.data.split(":")[1]
    if action == "cancel":
        await state.clear()
        await callback.message.edit_text("Добавление отменено.")
        await callback.answer()
        return

    data = await state.get_data()
    name = data['name']
    description = data['description']
    link = data['link']
    photo = data.get('photo')

    app_id = add_app(name, description, link, photo, platform=action)
    await state.clear()
    await callback.message.delete()
    await callback.message.answer(f"✅ Приложение добавлено с ID {app_id}.", reply_markup=reply_keyboard)
    await callback.answer()


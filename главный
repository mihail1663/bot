async def is_subscribed(user_id: int) -> bool:
    channel_id = get_setting('channel_id')
    group_id = get_setting('group_id')
    try:
        if channel_id:
            channel_member = await bot.get_chat_member(chat_id=channel_id, user_id=user_id)
            if channel_member.status not in ['member', 'administrator', 'creator']:
                return False
        if group_id:
            group_member = await bot.get_chat_member(chat_id=group_id, user_id=user_id)
            if group_member.status not in ['member', 'administrator', 'creator']:
                return False
        return True
    except Exception as e:
        logging.error(f"Subscription check error: {e}")
        return True

class SubscriptionMiddleware(BaseMiddleware):
    async def __call__(
        self,
        handler: Callable[[Message | CallbackQuery, Dict[str, Any]], Awaitable[Any]],
        event: Message | CallbackQuery,
        data: Dict[str, Any]
    ) -> Any:
        try:
            if isinstance(event, Message) and event.text and event.text.startswith('/start'):
                return await handler(event, data)

            user = event.from_user
            if is_admin(user):
                return await handler(event, data)

            if not await is_subscribed(user.id):
                channel_link = get_setting('channel_link')
                group_link = get_setting('group_link')
                text_parts = ["Для использования бота необходимо подписаться"]
                inline_buttons = []
                if channel_link:
                    text_parts.append(f"📢 на канал: {channel_link}")
                    inline_buttons.append([InlineKeyboardButton(text="📢 Канал", url=channel_link)])
                if group_link:
                    text_parts.append(f"👥 на группу: {group_link}")
                    inline_buttons.append([InlineKeyboardButton(text="👥 Группа", url=group_link)])
                if not channel_link and not group_link:
                    text_parts.append("(ссылки не заданы администратором)")
                text_parts.append("После подписки нажмите кнопку «Проверить подписку».")
                text = "\n".join(text_parts)
                inline_buttons.append([InlineKeyboardButton(text="✅ Проверить подписку", callback_data="check_sub")])
                keyboard = InlineKeyboardMarkup(inline_keyboard=inline_buttons)
                if isinstance(event, Message):
                    await event.answer(text, reply_markup=keyboard)
                else:
                    await event.message.answer(text, reply_markup=keyboard)
                    await event.answer()
                return
            return await handler(event, data)
        except Exception as e:
            logging.error(f"Middleware error: {e}")
            return await handler(event, data)

dp.message.middleware(SubscriptionMiddleware())

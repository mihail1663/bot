@dp.message(AddAdmin.waiting_for_input)
async def process_admin_management(message: Message, state: FSMContext):
    try:
        data = await state.get_data()
        action = data.get("action")
        input_text = message.text.strip()

        target_user_id = None
        target_username = None
        target_first_name = None

        try:
            target_user_id = int(input_text)
            user = get_user(target_user_id)
            if not user:
                try:
                    chat = await bot.get_chat(target_user_id)
                    target_username = chat.username
                    target_first_name = chat.first_name
                except Exception as e:
                    await message.answer("Пользователь с таким ID не найден в Telegram или бот не может его получить.")
                    await state.clear()
                    return
        except ValueError:
            username = extract_username(input_text)
            if not username:
                await message.answer("Неверный формат. Введите ID, @username или ссылку вида t.me/username.")
                return
            target_username = username
            conn = sqlite3.connect(DB_NAME)
            cur = conn.cursor()
            cur.execute("SELECT user_id, first_name FROM users WHERE username=?", (target_username,))
            row = cur.fetchone()
            conn.close()
            if row:
                target_user_id = row[0]
                target_first_name = row[1]
            else:
                try:
                    chat = await bot.get_chat(f"@{target_username}")
                    target_user_id = chat.id
                    target_first_name = chat.first_name
                except Exception as e:
                    await message.answer("Пользователь с таким username не найден в Telegram.")
                    await state.clear()
                    return

        if not target_user_id:
            await message.answer("Не удалось определить ID пользователя.")
            await state.clear()
            return

        if not get_user(target_user_id):
            add_user(target_user_id, target_username, target_first_name)

        if action == "add":
            conn = sqlite3.connect(DB_NAME)
            cur = conn.cursor()
            cur.execute("SELECT user_id FROM admins WHERE user_id=?", (target_user_id,))
            if cur.fetchone():
                conn.close()
                await message.answer("Этот пользователь уже является администратором.")
            else:
                if add_admin(target_user_id, message.from_user.id):
                    await message.answer(f"✅ Администратор (ID {target_user_id}) добавлен.")
                else:
                    await message.answer("❌ Ошибка при добавлении.")
            conn.close()
        elif action == "remove":
            if target_user_id == message.from_user.id:
                await message.answer("Нельзя удалить самого себя.")
            else:
                if remove_admin(target_user_id):
                    await message.answer(f"✅ Администратор (ID {target_user_id}) удалён.")
                else:
                    await message.answer("❌ Ошибка при удалении (возможно, не администратор).")
        await state.clear()
        await message.answer("👑 Панель администратора:", reply_markup=get_admin_keyboard())
    except Exception as e:
        logging.error(f"admin management error: {e}")
        await message.answer("Ошибка при обработке.")
        await state.clear()

@dp.callback_query(lambda c: c.data.startswith("sub:"))
async def process_subscription_callback(callback: CallbackQuery, state: FSMContext):
    if not is_admin(callback.from_user):
        await callback.answer("Недостаточно прав.")
        return
    action = callback.data.split(":")[1]
    if action == "set_channel_link":
        await callback.message.edit_text("Введите ссылку на канал (например, https://t.me/...):")
        await state.set_state(SetSubscription.waiting_for_channel_link)
    elif action == "set_channel_id":
        await callback.message.edit_text("Введите ID канала (например, -1001234567890):")
        await state.set_state(SetSubscription.waiting_for_channel_id)
    elif action == "set_group_link":
        await callback.message.edit_text("Введите ссылку на группу (например, https://t.me/...):")
        await state.set_state(SetSubscription.waiting_for_group_link)
    elif action == "set_group_id":
        await callback.message.edit_text("Введите ID группы (например, @group или -100...):")
        await state.set_state(SetSubscription.waiting_for_group_id)
    await callback.answer()


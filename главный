        apps = get_all_apps()
        app_to_delete = next((a for a in apps if a[0] == app_id), None)
        if not app_to_delete:
            await callback.answer("❌ Элемент не найден.")
            return
        ctype = app_to_delete[6]
        type_ru = "приложений" if ctype == "app" else "сайтов"
        if delete_app(app_id):
            count_after = get_count_by_type(ctype)
            await callback.answer(f"✅ Элемент ID {app_id} удалён. Осталось {count_after} {type_ru}.")
        else:
            await callback.answer(f"❌ Ошибка при удалении.")
            return
        apps = get_all_apps()
        if apps:
            kb_buttons = []
            for app in apps:
                app_id, name, _, _, _, platform, ctype = app
                short_name = name if len(name) <= 30 else name[:27] + "..."
                platform_emoji = "📱" if platform == "android" else "🍏" if platform == "ios" else "🔄"
                type_emoji = "📱" if ctype == "app" else "🌐"
                kb_buttons.append([InlineKeyboardButton(
                    text=f"ID {app_id}: {type_emoji} {short_name} {platform_emoji}",
                    callback_data=f"del:{app_id}"
                )])
            kb_buttons.append([InlineKeyboardButton(text="◀️ Назад", callback_data="admin:back")])
            keyboard = InlineKeyboardMarkup(inline_keyboard=kb_buttons)
            await callback.message.edit_text("Выберите элемент для удаления:", reply_markup=keyboard)
        else:
            await callback.message.edit_text("Список пуст.", reply_markup=get_admin_keyboard())
    except Exception as e:
        logging.error(f"delete error: {e}")

@dp.message(AddAdmin.waiting_for_input)
async def process_admin_management(message: Message, state: FSMContext):
    try:
        data = await state.get_data()
        action = data.get("action")
        input_text = message.text.strip()

        target_user_id = None
        if input_text.startswith('@'):
            username = input_text[1:].lower()
            conn = sqlite3.connect(DB_NAME)
            cur = conn.cursor()
            cur.execute("SELECT user_id FROM users WHERE username=?", (username,))
            row = cur.fetchone()
            conn.close()
            if row:
                target_user_id = row[0]
            else:
                await message.answer("Пользователь с таким username не найден в базе. Возможно, он ещё не запускал бота.")
                await state.clear()
                return
        else:
            try:
                target_user_id = int(input_text)
                if not get_user(target_user_id):
                    await message.answer("Пользователь с таким ID не найден в базе.")
                    await state.clear()
                    return
            except ValueError:
                await message.answer("Неверный формат. Введите ID или @username.")
                return

        if action == "add":
            if get_user(target_user_id) is None:
                await message.answer("Пользователь не найден в базе.")
                await state.clear()
                return
            conn = sqlite3.connect(DB_NAME)
            cur = conn.cursor()
            cur.execute("SELECT user_id FROM admins WHERE user_id=?", (target_user_id,))
            if cur.fetchone():
                conn.close()
                await message.answer("Этот пользователь уже является администратором.")
            else:
                if add_admin(target_user_id, message.from_user.id):
                    await message.answer(f"✅ Администратор (ID {target_user_id}) добавлен.")
                else:
                    await message.answer("❌ Ошибка при добавлении.")
            conn.close()
        elif action == "remove":
            if target_user_id == message.from_user.id:
                await message.answer("Нельзя удалить самого себя.")
            else:
                if remove_admin(target_user_id):
                    await message.answer(f"✅ Администратор (ID {target_user_id}) удалён.")
                else:
                    await message.answer("❌ Ошибка при удалении (возможно, не администратор).")
        await state.clear()
        await message.answer("👑 Панель администратора:", reply_markup=get_admin_keyboard())
    except Exception as e:
        logging.error(f"admin management error: {e}")
        await message.answer("Ошибка при обработке.")
        await state.clear()


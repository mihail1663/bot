@dp.message(AddApp.photo, F.photo)
async def add_photo(message: Message, state: FSMContext):
    photo_file_id = message.photo[-1].file_id
    data = await state.get_data()
    content_type = data['content_type']
    count_before = get_count_by_type(content_type)
    app_id = add_app(
        name=data['name'],
        description=data['description'],
        link=data['link'],
        photo_file_id=photo_file_id,
        platform=data['platform'],
        type=content_type
    )
    if app_id:
        number = count_before + 1
        type_text = "приложение" if content_type == "app" else "сайт"
        await message.answer(f"✅ {type_text.capitalize()} добавлено с ID {app_id}. Это {type_text} №{number}.", reply_markup=reply_keyboard)
    else:
        await message.answer("❌ Ошибка при добавлении.")
    await state.clear()

